# ── Public ────────────────────────────────────────────────────────────────
# Canonical site URL (used for SEO metadata / sitemap)
NEXT_PUBLIC_SITE_URL=https://www.via-we.com
# WhatsApp number in international format, digits only (Vijay Budati)
NEXT_PUBLIC_WHATSAPP_NUMBER=916304579933
# Optional scheduling link (Calendly / Cal.com). Falls back to WhatsApp if unset.
NEXT_PUBLIC_SCHEDULER_URL=

# ── Supabase (lead storage) ───────────────────────────────────────────────
# Run supabase/migrations/0001_leads.sql against your project first.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── n8n (automation hub: CRM, Google Sheets, WhatsApp notify) ─────────────
# Create an n8n Webhook node and paste its production URL here.
# The full lead payload is POSTed as JSON — fan it out to Sheets/CRM/WhatsApp.
N8N_WEBHOOK_URL=

# ── Resend (email notification) ───────────────────────────────────────────
RESEND_API_KEY=
LEAD_NOTIFY_TO=via.we.org@gmail.com
LEAD_NOTIFY_FROM=Via-We Website <leads@via-we.com>

# ── Google Sheets (direct, optional — n8n already covers Sheets) ──────────
# Google Apps Script "web app" URL that appends a row per POSTed lead.
SHEETS_WEBHOOK_URL=
